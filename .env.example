# SDK
AFR_API_KEY=dev_key
AFR_ENDPOINT=http://localhost:4318
AFR_ENVIRONMENT=development
AFR_CAPTURE_MODE=redacted
AFR_CAPTURE_PROMPTS=true
AFR_CAPTURE_RESPONSES=true
AFR_REDACTION_MODE=strict

# Collector (local SQLite — default)
AFR_STORAGE_BACKEND=sqlite
AFR_DATABASE_PATH=./data/afr.db
AFR_HOST=0.0.0.0
AFR_PORT=4318

# Collector (production Postgres)
# AFR_STORAGE_BACKEND=postgres
# AFR_DATABASE_URL=postgresql://afr:afr@localhost:5432/afr

# ClickHouse analytics (optional)
# AFR_CLICKHOUSE_URL=http://afr:afr@localhost:8123

# Object storage for large payloads (optional, S3-compatible / MinIO)
# AFR_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# AFR_OBJECT_STORAGE_BUCKET=afr-payloads
# AFR_OBJECT_STORAGE_ACCESS_KEY=minioadmin
# AFR_OBJECT_STORAGE_SECRET_KEY=minioadmin
# AFR_BLOB_THRESHOLD_BYTES=4096

# OTLP export to external observability (optional)
# AFR_OTLP_EXPORT_ENDPOINT=https://otel-collector.example/v1/traces
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces

# Web UI
NEXT_PUBLIC_AFR_API_URL=http://localhost:4318